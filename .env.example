OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
DATABASE_URL=postgresql://avtobaks:avtobaks@localhost:5433/avtobaks?schema=public
ADMIN_PASSWORD=admin123
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
PRISMA_QUERY_ENGINE_LIBRARY=node_modules/.pnpm/@prisma+engines@6.19.0/node_modules/@prisma/engines/query_engine-windows.dll.node
VIN_SELECTOR_PYTHON=Avtobaks_API/.venv/Scripts/python.exe

# Optional external catalog service. If set, the public site reads catalog data
# from this service first, then falls back to local JSON, Prisma, and demo data.
CATALOG_SERVICE_URL=
CATALOG_SERVICE_TOKEN=
CATALOG_SERVICE_TIMEOUT_MS=8000

# Optional external admin catalog service for product search/edit/import.
CATALOG_ADMIN_SERVICE_URL=
CATALOG_ADMIN_SERVICE_TOKEN=

# PartsAPI — ключи для VIN декодирования (получить на partsapi.ru)
PARTSAPI_ENDPOINT=https://api.partsapi.ru
PARTSAPI_KEY_VINDECODE=
PARTSAPI_KEY_VINDECODE_OE=
PARTSAPI_KEY_GET_PARTS_BY_VIN=
PARTSAPI_LANG=16
